# ============================================================================
# crm-bot production — Node C (crm-bot, VPC 10.104.0.3)
# chmod 600 .env.prod — DO NOT commit this file. This is a TEMPLATE only —
# every value below is a placeholder; generate real secrets per deploy target.
# Used by: docker compose -f docker-compose.prod.yml --env-file .env.prod ...
# ============================================================================

# ── Datastore credentials (consumed by compose for db/redis containers) ──────
POSTGRES_PASSWORD=replace-with-strong-random-password
REDIS_PASSWORD=replace-with-strong-random-password

# ── Database & cache ─────────────────────────────────────────────────────────
DATABASE_URL=postgresql://postgres:replace-with-strong-random-password@crm-bot-db:5432/typebot
WORKFLOWS_DATABASE_URL=postgresql://postgres:replace-with-strong-random-password@crm-bot-db:5432/typebot
REDIS_URL=redis://:replace-with-strong-random-password@crm-bot-redis:6379/0
ENCRYPTION_SECRET=replace-with-32-char-hex-from-openssl-rand-hex-16

# ── Public URLs ──────────────────────────────────────────────────────────────
NEXTAUTH_URL=https://bot.crmsaudi.dev
NEXT_PUBLIC_VIEWER_URL=https://chat.crmsaudi.dev
ADMIN_EMAIL=

# ── CRM integration ─────────────────────────────────────────────────────────
CRM_BOT_SSO_LOCKDOWN=true
NEXT_PUBLIC_CRM_BOT_SSO_LOCKDOWN=true
CRM_BOT_INTERNAL_SECRET=replace-with-shared-secret-matching-crm-api
CRM_API_INTERNAL_URL=https://api.crmsaudi.dev

# ── Keycloak SSO ─────────────────────────────────────────────────────────────
KEYCLOAK_CLIENT_ID=crm-bot
KEYCLOAK_CLIENT_SECRET=replace-with-keycloak-client-secret
KEYCLOAK_ISSUER=https://auth.crmsaudi.dev/realms/crm-saas

# ── Workflows service (in-cluster RPC) ───────────────────────────────────────
WORKFLOWS_SERVER_PORT=3000
WORKFLOWS_RPC_URL=http://crm-bot-workflows:3000/rpc
WORKFLOWS_RPC_SECRET=replace-with-strong-random-secret

# ── S3 (DigitalOcean Spaces) ─────────────────────────────────────────────────
S3_ACCESS_KEY=replace-with-do-spaces-access-key
S3_SECRET_KEY=replace-with-do-spaces-secret-key
S3_BUCKET=crmsaudi
S3_ENDPOINT=sgp1.digitaloceanspaces.com
S3_REGION=sgp1
S3_SSL=true

# ── SMTP (Gmail) ─────────────────────────────────────────────────────────────
SMTP_HOST=smtp.gmail.com
SMTP_PORT=587
SMTP_SECURE=false
SMTP_USERNAME=
SMTP_PASSWORD=replace-with-gmail-app-password
NEXT_PUBLIC_SMTP_FROM=CRM Bot <alerts@crmsaudi.dev>

# ── Node runtime ─────────────────────────────────────────────────────────────
NODE_OPTIONS=--no-node-snapshot
