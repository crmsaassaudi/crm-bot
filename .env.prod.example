# ============================================================================
# crm-bot production env — Node C (10.104.0.4 / 159.89.199.112), load-test env.
# Copy to .env.prod on Node C and fill the <...> placeholders. DO NOT commit .env.prod.
# Generate secrets:  openssl rand -base64 24   (ENCRYPTION_SECRET must be EXACTLY 32 chars)
# Used by:  docker compose -f docker-compose.prod.yml --env-file .env.prod ...
# ============================================================================

# --- Datastore credentials (consumed by compose substitution for db/redis/minio) ---
POSTGRES_PASSWORD=<pg_password>
REDIS_PASSWORD=<redis_password>

# --- App: database / redis / encryption ---
# Hostnames are the compose service names on network crm_bot_net.
DATABASE_URL=postgresql://postgres:<pg_password>@crm-bot-db:5432/typebot
WORKFLOWS_DATABASE_URL=postgresql://postgres:<pg_password>@crm-bot-db:5432/typebot
REDIS_URL=redis://:<redis_password>@crm-bot-redis:6379/0
ENCRYPTION_SECRET=<exactly_32_char_secret_______>

# --- Public URLs (must match Keycloak redirect URIs + nginx vhosts) ---
NEXTAUTH_URL=https://bot.crmsaudi.dev
NEXT_PUBLIC_VIEWER_URL=https://chat.crmsaudi.dev
ADMIN_EMAIL=admin@crmsaudi.dev

# --- CRM integration (CRM_BOT_INTERNAL_SECRET MUST equal the value set on Node A crm-api) ---
CRM_BOT_SSO_LOCKDOWN=true
# Client-readable mirror of CRM_BOT_SSO_LOCKDOWN — MUST match the value above.
NEXT_PUBLIC_CRM_BOT_SSO_LOCKDOWN=true
CRM_BOT_INTERNAL_SECRET=<shared_internal_secret_matches_node_a>
# URL for the builder to call crm-api's internal endpoints (channels, etc.)
CRM_API_INTERNAL_URL=https://api.crmsaudi.dev

# --- Keycloak SSO (client crm-bot, realm crm-saas) ---
KEYCLOAK_CLIENT_ID=crm-bot
KEYCLOAK_CLIENT_SECRET=<keycloak_client_secret>
KEYCLOAK_ISSUER=https://auth.crmsaudi.dev/realms/crm-saas

# --- Workflows service (in-cluster RPC) ---
WORKFLOWS_SERVER_PORT=3000
WORKFLOWS_RPC_URL=http://crm-bot-workflows:3000/rpc
WORKFLOWS_RPC_SECRET=<workflows_rpc_secret>

# --- S3 (MinIO in-cluster) ---
S3_ACCESS_KEY=<minio_access_key>
S3_SECRET_KEY=<minio_secret_key>
S3_BUCKET=typebot
S3_ENDPOINT=crm-bot-minio
S3_PORT=9000
S3_SSL=false

# --- Node ---
NODE_OPTIONS=--no-node-snapshot
